# ============================================================
# SRP AI Labs — SmartRecruit Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control!
# ============================================================

# ── Google OAuth ─────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth ──────────────────────────────────────────────────
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://recruit.srpailabs.com

# ── PostgreSQL Database ───────────────────────────────────────
DATABASE_URL=postgresql://srp_auth:your-db-password@localhost:5432/srp_auth

# ── AI (OpenRouter or OpenAI) ─────────────────────────────────
# OpenRouter: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini
# Standard OpenAI: OPENAI_BASE_URL=https://api.openai.com/v1  OPENAI_MODEL=gpt-4o-mini

